{
  "entities": {
    "player": {
      "title": "Player",
      "description": "A Minecraft player with rankings across different PvP categories.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Minecraft username" },
        "uuid": { "type": "string", "description": "Minecraft UUID" },
        "skinUrl": { "type": "string", "description": "URL to the player's skin avatar" },
        "pose": { "type": "string", "description": "Preferred display pose for the player skin" },
        "rankings": {
          "type": "object",
          "description": "Map of category IDs to tier IDs (e.g., { 'cpvp': 'HT1' })"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of achievement badge IDs"
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date-time" },
              "points": { "type": "number" }
            }
          },
          "description": "Historical point snapshots for progress charts"
        },
        "votes": {
          "type": "object",
          "properties": {
            "up": { "type": "number" },
            "down": { "type": "number" }
          },
          "description": "Community votes for rank change"
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "uuid", "rankings"]
    },
    "activity": {
      "title": "Recent Activity",
      "description": "Log of recent rank changes and player additions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "type": { "type": "string", "enum": ["rank_up", "rank_down", "new_player", "badge_earned"] },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "playerName", "type", "timestamp"]
    },
    "category": {
      "title": "PvP Category",
      "description": "A specific PvP mode (e.g., Crystal PvP, UHC).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "tier": {
      "title": "Tier",
      "description": "A ranking tier (e.g., HT1, LT1).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string", "description": "Tailwind color class" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "color", "order"]
    }
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "player",
      "description": "Collection of ranked players"
    },
    "/categories/{categoryId}": {
      "schema": "category",
      "description": "Available PvP categories"
    },
    "/tiers/{tierId}": {
      "schema": "tier",
      "description": "Available ranking tiers"
    },
    "/activity/{activityId}": {
      "schema": "activity",
      "description": "Log of recent site events"
    }
  }
}
