// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: players
// Document ID: playerId (string)
// Fields:
//   - name: string (required)
//   - uuid: string (required)
//   - skinUrl: string (optional)
//   - rankings: map (required) - categoryId -> tierId
//   - updatedAt: timestamp (optional)
//
// Collection: categories
// Document ID: categoryId (string)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - icon: string (optional)
//   - description: string (optional)
//   - order: number (required)
//
// Collection: tiers
// Document ID: tierId (string)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - color: string (required)
//   - order: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "matvey.zingaliuk@gmail.com");
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'uuid', 'rankings']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 32 &&
             data.uuid is string && data.uuid.size() > 0 && data.uuid.size() < 64 &&
             data.rankings is map && data.rankings.size() < 20;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['playerId', 'playerName', 'type', 'timestamp']) &&
             data.playerName is string && data.playerName.size() < 32 &&
             data.details is string && data.details.size() < 256;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'order']) &&
             data.id is string && data.name is string && data.order is number;
    }

    function isValidTier(data) {
      return data.keys().hasAll(['id', 'name', 'color', 'order']) &&
             data.id is string && data.name is string && data.color is string && data.order is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    function isValidVoteUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['votes']) && 
             request.resource.data.votes.keys().hasOnly(['up', 'down']) &&
             (request.resource.data.votes.get('up', 0) >= resource.data.votes.get('up', 0)) &&
             (request.resource.data.votes.get('down', 0) >= resource.data.votes.get('down', 0));
    }

    match /players/{playerId} {
      allow read: if true;
      allow update: if (isAdmin() && isValidPlayer(request.resource.data)) || isValidVoteUpdate();
      allow create: if isAdmin() && isValidPlayer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /activity/{activityId} {
      allow read: if true;
      allow write: if isAdmin() && isValidActivity(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tiers/{tierId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
